# Copy to .env.local for local `vercel dev` (never commit .env.local)
# Or set in Vercel Dashboard → Project → Settings → Environment Variables
# Test keys: https://dashboard.stripe.com/test/apikeys

STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Prefer a restricted key (rk_...) with Checkout Sessions Read + Write in production
# STRIPE_SECRET_KEY=rk_live_...

# Optional: Stripe Price IDs (create in Dashboard → Products)
# STRIPE_PRICE_STRANGER=price_...
# STRIPE_PRICE_ACQUAINTANCE=price_...
# STRIPE_PRICE_FRIEND=price_...
# STRIPE_PRICE_BESTIE=price_...
